{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": false,
    "types": ["electron-vite/node", "node"],
    "outDir": "out"
  },
  "include": ["electron.vite.config.*", "electron/**/*"]
}
